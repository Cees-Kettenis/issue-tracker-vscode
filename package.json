{
  "name": "local-issues-tracker",
  "displayName": "Local Issues Tracker",
  "description": "A lightweight local issue tracker inside VS Code.",
  "version": "1.0.0",
  "license": "MIT",
  "icon": "media/marketplace-icon.png",
  "publisher": "Cees Kettenis",
  "repository": "https://github.com/cees/issue-tracker-vscode",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:localIssues.tree",
    "onView:localIssues.details",
    "onCommand:localIssues.refresh",
    "onCommand:localIssues.createIssue",
    "onCommand:localIssues.createGroup",
    "onCommand:localIssues.deleteGroup",
    "onCommand:localIssues.importIssues",
    "onCommand:localIssues.exportIssues",
    "onCommand:localIssues.toggleHideCompleted",
    "onCommand:localIssues.showCompletedIssues",
    "onCommand:localIssues.hideCompletedIssues",
    "onCommand:localIssues.setStatus",
    "onCommand:localIssues.setPriority",
    "onCommand:localIssues.deleteIssue",
    "onCommand:localIssues.completeIssue",
    "onCommand:localIssues.editIssue"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Local Issues",
      "properties": {
        "localIssues.filePath": {
          "type": "string",
          "default": ".vscode/issues.json",
          "description": "Relative or absolute path to the JSON file that stores issues for the current workspace."
        },
        "localIssues.hideCompleted": {
          "type": "boolean",
          "default": false,
          "description": "Hide issues marked as done in the tree view."
        }
      }
    },
    "commands": [
      {
        "command": "localIssues.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "localIssues.createIssue",
        "title": "Add Issue",
        "icon": "$(add)"
      },
      {
        "command": "localIssues.createGroup",
        "title": "Add Group",
        "icon": "$(new-folder)"
      },
      {
        "command": "localIssues.deleteGroup",
        "title": "Delete Group",
        "icon": {
          "light": "media/delete-red.svg",
          "dark": "media/delete-red.svg"
        }
      },
      {
        "command": "localIssues.editIssue",
        "title": "Edit Issue",
        "icon": "$(edit)"
      },
      {
        "command": "localIssues.importIssues",
        "title": "Import Issues",
        "icon": "$(cloud-download)"
      },
      {
        "command": "localIssues.exportIssues",
        "title": "Export Issues",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "localIssues.toggleHideCompleted",
        "title": "Toggle Hide Completed",
        "icon": "$(eye-closed)"
      },
      {
        "command": "localIssues.showCompletedIssues",
        "title": "Show Completed",
        "icon": "$(eye)"
      },
      {
        "command": "localIssues.hideCompletedIssues",
        "title": "Hide Completed",
        "icon": "$(eye-closed)"
      },
      {
        "command": "localIssues.setStatus",
        "title": "Change Status",
        "icon": "$(symbol-constant)"
      },
      {
        "command": "localIssues.setPriority",
        "title": "Change Priority",
        "icon": "$(arrow-up)"
      },
      {
        "command": "localIssues.deleteIssue",
        "title": "Delete Issue",
        "icon": {
          "light": "media/delete-red.svg",
          "dark": "media/delete-red.svg"
        }
      },
      {
        "command": "localIssues.completeIssue",
        "title": "Complete Issue",
        "icon": "$(check)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localIssues",
          "title": "Issues",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "localIssues": [
        {
          "id": "localIssues.tree",
          "name": "Issues"
        },
        {
          "id": "localIssues.details",
          "name": "Details",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "localIssues.createGroup",
          "when": "view == localIssues.tree",
          "group": "navigation",
          "icon": "$(new-folder)"
        },
      {
        "command": "localIssues.refresh",
        "when": "view == localIssues.tree",
        "group": "navigation",
        "icon": "$(refresh)"
      },
      {
        "command": "localIssues.importIssues",
        "when": "view == localIssues.tree",
        "group": "navigation@1",
        "icon": "$(cloud-download)"
      },
      {
        "command": "localIssues.exportIssues",
        "when": "view == localIssues.tree",
        "group": "navigation@2",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "localIssues.hideCompletedIssues",
        "when": "view == localIssues.tree && !localIssues.hideCompleted",
        "group": "navigation@3",
        "icon": "$(eye)"
      },
      {
        "command": "localIssues.showCompletedIssues",
        "when": "view == localIssues.tree && localIssues.hideCompleted",
        "group": "navigation@4",
        "icon": "$(eye-closed)"
      }
      ],
      "view/item/context": [
        {
          "command": "localIssues.createIssue",
          "when": "view == localIssues.tree && viewItem == localIssuesGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "localIssues.deleteGroup",
          "when": "view == localIssues.tree && viewItem == localIssuesGroup",
          "group": "inline@1",
          "icon": {
            "light": "media/delete-red.svg",
            "dark": "media/delete-red.svg"
          }
        },
        {
          "command": "localIssues.editIssue",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "inline"
        },
        {
          "command": "localIssues.completeIssue",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "inline@1",
          "icon": "$(check)"
        },
        {
          "command": "localIssues.deleteIssue",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "inline@2"
        },
        {
          "command": "localIssues.setStatus",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "navigation"
        },
        {
          "command": "localIssues.setPriority",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "navigation"
        },
        {
          "command": "localIssues.deleteIssue",
          "when": "view == localIssues.tree && viewItem == localIssuesIssue",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "prepublish": "tsc -p .",
    "lint": "tsc -p . --noEmit",
    "test": "tsc -p . && node --test test"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/vscode": "^1.86.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.0+sha1.46a0bef28aad690765997ab6da6d5475bdd4148e"
}
